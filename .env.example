APP_ENV=development

# DATABASE_URL e POSTGRES_* devem representar a mesma instância local.
# Estas credenciais são exclusivas para desenvolvimento e não devem ser usadas em produção.
DATABASE_URL=postgresql+psycopg://supervisor_ai:supervisor_ai@localhost:5432/supervisor_ai
POSTGRES_DB=supervisor_ai
POSTGRES_USER=supervisor_ai
POSTGRES_PASSWORD=supervisor_ai
POSTGRES_PORT=5432
